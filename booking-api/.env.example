# ── Google Calendar (Meet link + invites) ──────────────────────────────
# Reuse the SAME values from gioquote-sprint1/apps/web/.env.local
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
GOOGLE_REFRESH_TOKEN="your-refresh-token"

# ── Booking email (Gmail App Password) ──────────────────────────────────
SMTP_FROM_EMAIL="jukopila.giovanny15@gmail.com"
SMTP_APP_PASSWORD="your-gmail-app-password"

# Where the "new booking" notification is sent (your inbox).
OWNER_EMAIL="jukopila.giovanny@hotmail.com"

# ── Behaviour ───────────────────────────────────────────────────────────
# Timezone the slots are offered in (IANA name). Malta = Europe/Malta.
BOOKING_TIMEZONE="Europe/Malta"

# Restrict who can call the API. Use your live site origin in production,
# e.g. https://giovannyjukopila.github.io  (use * only while testing).
ALLOWED_ORIGIN="*"
